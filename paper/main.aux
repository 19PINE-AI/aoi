\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Trajectory comparison on two representative tasks (\emph  {illustrative; cherry-picked to expose the mechanism}). \textbf  {Top:} Meeting task (B-E1) where the launch date is spoken aloud. The standard agent cannot hear it and exhausts its step budget on 15 futile \texttt  {wait()} steps. The AOI agent transcribes the audio, hears ``April 28th,'' and acts in 2 steps. \textbf  {Bottom:} Video task (C-E1) where the answer appears in a terminal recording. The standard agent needs 6 steps with lucky timing; the AOI agent's narration captures the content in 1 step.\relax }}{12}{figure.caption.9}\protected@file@percent }
\newlabel{fig:trajectories}{{5}{12}{Trajectory comparison on two representative tasks (\emph {illustrative; cherry-picked to expose the mechanism}). \textbf {Top:} Meeting task (B-E1) where the launch date is spoken aloud. The standard agent cannot hear it and exhausts its step budget on 15 futile \texttt {wait()} steps. The AOI agent transcribes the audio, hears ``April 28th,'' and acts in 2 steps. \textbf {Bottom:} Video task (C-E1) where the answer appears in a terminal recording. The standard agent needs 6 steps with lucky timing; the AOI agent's narration captures the content in 1 step.\relax }{figure.caption.9}{}}
