\@writefile{lot}{\contentsline {table}{\numberline {22}{\ignorespaces Per-task adapter sanity-check outcomes for each streaming baseline. Every adapter drives the browser and emits valid tool calls (\texttt  {click}, \texttt  {fill}, \texttt  {type\_text}) on every task. Every attempted action lands on the DOM, so the audio-subset failures are content-driven rather than infrastructural. The older adapters score 0/5 task-correct, failing by wrong target (e.g.\ F-E2 cookies dismissed instead of accepted), hallucinated content (e.g.\ C-E1), or premature commit (e.g.\ I-E1), whereas the current GA \texttt  {gpt-realtime-2} reaches 3/5, closer to but still below the AOI reference, consistent with the audio subset (Table\nobreakspace  {}\ref  {tab:streaming}).\relax }}{32}{table.caption.35}\protected@file@percent }
\newlabel{tab:streaming_sanity_detail}{{22}{32}{Per-task adapter sanity-check outcomes for each streaming baseline. Every adapter drives the browser and emits valid tool calls (\texttt {click}, \texttt {fill}, \texttt {type\_text}) on every task. Every attempted action lands on the DOM, so the audio-subset failures are content-driven rather than infrastructural. The older adapters score 0/5 task-correct, failing by wrong target (e.g.\ F-E2 cookies dismissed instead of accepted), hallucinated content (e.g.\ C-E1), or premature commit (e.g.\ I-E1), whereas the current GA \texttt {gpt-realtime-2} reaches 3/5, closer to but still below the AOI reference, consistent with the audio subset (Table~\ref {tab:streaming}).\relax }{table.caption.35}{}}
