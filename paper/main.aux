\@writefile{toc}{\contentsline {section}{\numberline {G}CLIP Threshold Calibration}{29}{appendix.G}\protected@file@percent }
\newlabel{app:theta}{{G}{29}{CLIP Threshold Calibration}{appendix.G}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces \textbf  {CLIP threshold ($\theta $) sensitivity} on 40 visual tasks (categories C--F) with Claude Sonnet\nobreakspace  {}4.6. Error bars are 95\% Wilson confidence intervals at $N{=}40$ ($\pm $9.5--12.1\,pp). Point estimates remain within an 80--90\% band (shaded) across a $15\times $ range of $\theta $, but the CIs overlap heavily, so we cannot distinguish individual thresholds at this sample size. $\theta $ values are placed at uniform spacing on the axis (not to scale). The bimodal distribution of CLIP distances (near-zero for unchanged content, large for meaningful changes) makes the method naturally insensitive to $\theta $.\relax }}{30}{figure.caption.32}\protected@file@percent }
\newlabel{fig:theta}{{13}{30}{\textbf {CLIP threshold ($\theta $) sensitivity} on 40 visual tasks (categories C--F) with Claude Sonnet~4.6. Error bars are 95\% Wilson confidence intervals at $N{=}40$ ($\pm $9.5--12.1\,pp). Point estimates remain within an 80--90\% band (shaded) across a $15\times $ range of $\theta $, but the CIs overlap heavily, so we cannot distinguish individual thresholds at this sample size. $\theta $ values are placed at uniform spacing on the axis (not to scale). The bimodal distribution of CLIP distances (near-zero for unchanged content, large for meaningful changes) makes the method naturally insensitive to $\theta $.\relax }{figure.caption.32}{}}
