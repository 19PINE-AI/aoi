\citation{gemini3flash}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Grok-4 on DynaCU-Bench (100 dynamic tasks). The AOI delivers a significant +21\,pp gain ($p\!=\!3.0\!\times \!10^{-6}$), within the +17--+48\,pp band reported in Table\nobreakspace  {}\ref  {tab:main} for the other five models. Grok-4's absolute scores sit near the bottom of the range; manual log inspection shows this is driven by per-inference latency ($\sim $80--180\,s/call), which causes the agent to time out before completing more than a few steps on Medium and Hard tasks.\relax }}{12}{table.caption.8}\protected@file@percent }
\newlabel{tab:grok}{{4}{12}{Grok-4 on DynaCU-Bench (100 dynamic tasks). The AOI delivers a significant +21\,pp gain ($p\!=\!3.0\!\times \!10^{-6}$), within the +17--+48\,pp band reported in Table~\ref {tab:main} for the other five models. Grok-4's absolute scores sit near the bottom of the range; manual log inspection shows this is driven by per-inference latency ($\sim $80--180\,s/call), which causes the agent to time out before completing more than a few steps on Medium and Hard tasks.\relax }{table.caption.8}{}}
