\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Glossary of all observation modes used in the paper. KF = inter-step keyframes (with selection strategy); Audio = Whisper transcripts of system audio; Narr.\ = CU-model-generated visual narration persisted as text; [PAGE EL] = DOM element list in the prompt; Traj.\ = structured prior-step trajectory wrapping. \textbf  {Standard} and \textbf  {AOI full} are run on all models; other modes are Claude Sonnet\nobreakspace  {}4.6 ablations, with two exceptions: the selection ablation is also replicated on Qwen3-VL-32B, and \texttt  {standard\_audio}, \texttt  {aoi\_audio}, and the keyframe probes are Gemini\nobreakspace  {}3\nobreakspace  {}Flash diagnostics.\relax }}{9}{table.caption.5}\protected@file@percent }
\newlabel{tab:modes}{{2}{9}{Glossary of all observation modes used in the paper. KF = inter-step keyframes (with selection strategy); Audio = Whisper transcripts of system audio; Narr.\ = CU-model-generated visual narration persisted as text; [PAGE EL] = DOM element list in the prompt; Traj.\ = structured prior-step trajectory wrapping. \textbf {Standard} and \textbf {AOI full} are run on all models; other modes are Claude Sonnet~4.6 ablations, with two exceptions: the selection ablation is also replicated on Qwen3-VL-32B, and \texttt {standard\_audio}, \texttt {aoi\_audio}, and the keyframe probes are Gemini~3~Flash diagnostics.\relax }{table.caption.5}{}}
