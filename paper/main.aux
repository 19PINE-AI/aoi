\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Ablation study on Claude Sonnet\nobreakspace  {}4.6: contribution of each AOI component. All configurations include per-category breakdown for categories most affected.\relax }}{11}{table.caption.10}\protected@file@percent }
\newlabel{tab:ablation}{{5}{11}{Ablation study on Claude Sonnet~4.6: contribution of each AOI component. All configurations include per-category breakdown for categories most affected.\relax }{table.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Ablation: progressive contribution of each AOI component} (Claude Sonnet\nobreakspace  {}4.6). Inter-step keyframes provide +20\,pp (any selection method achieves this; see Table\nobreakspace  {}\ref  {tab:ablation}). ASR adds +6\,pp (hearing speech and sounds). Visual narration adds +18\,pp---the largest single-component gain---demonstrating that \emph  {retaining} visual information as persistent text is as important as \emph  {capturing} it.\relax }}{11}{figure.caption.11}\protected@file@percent }
\newlabel{fig:ablation}{{6}{11}{\textbf {Ablation: progressive contribution of each AOI component} (Claude Sonnet~4.6). Inter-step keyframes provide +20\,pp (any selection method achieves this; see Table~\ref {tab:ablation}). ASR adds +6\,pp (hearing speech and sounds). Visual narration adds +18\,pp---the largest single-component gain---demonstrating that \emph {retaining} visual information as persistent text is as important as \emph {capturing} it.\relax }{figure.caption.11}{}}
\@writefile{loa}{\contentsline {algorithm}{\numberline {1}{\ignorespaces CLIP-Based Adaptive Keyframe Extraction\relax }}{12}{algorithm.1}\protected@file@percent }
\newlabel{alg:keyframe}{{1}{12}{CLIP-Based Adaptive Keyframe Extraction\relax }{algorithm.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {CLIP threshold ($\theta $) sensitivity} on 40 visual tasks (categories C--F) with Claude Sonnet\nobreakspace  {}4.6. Performance remains within an 80--90\% band (shaded) across a $15\times $ range of $\theta $, from 0.02 (capturing minor changes) to 0.30 (only major visual shifts). The bimodal distribution of CLIP distances---near-zero for unchanged content, large for meaningful changes---makes the method naturally insensitive to $\theta $.\relax }}{12}{figure.caption.12}\protected@file@percent }
\newlabel{fig:theta}{{7}{12}{\textbf {CLIP threshold ($\theta $) sensitivity} on 40 visual tasks (categories C--F) with Claude Sonnet~4.6. Performance remains within an 80--90\% band (shaded) across a $15\times $ range of $\theta $, from 0.02 (capturing minor changes) to 0.30 (only major visual shifts). The bimodal distribution of CLIP distances---near-zero for unchanged content, large for meaningful changes---makes the method naturally insensitive to $\theta $.\relax }{figure.caption.12}{}}
