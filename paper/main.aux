\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Trajectory comparison on two representative tasks (\emph  {illustrative, cherry-picked to expose the mechanism}). \textbf  {Top:} Meeting task where the launch date is spoken aloud. The standard agent cannot hear it and exhausts its step budget on 15 \texttt  {wait()} steps. The AOI agent transcribes the audio, hears ``April 28th,'' and acts in 2 steps. \textbf  {Bottom:} Screencast task where the answer appears in a terminal recording. The standard agent needs 6 steps with lucky timing. The AOI agent's narration captures the content in 1 step.\relax }}{27}{figure.caption.26}\protected@file@percent }
\newlabel{fig:trajectories}{{11}{27}{Trajectory comparison on two representative tasks (\emph {illustrative, cherry-picked to expose the mechanism}). \textbf {Top:} Meeting task where the launch date is spoken aloud. The standard agent cannot hear it and exhausts its step budget on 15 \texttt {wait()} steps. The AOI agent transcribes the audio, hears ``April 28th,'' and acts in 2 steps. \textbf {Bottom:} Screencast task where the answer appears in a terminal recording. The standard agent needs 6 steps with lucky timing. The AOI agent's narration captures the content in 1 step.\relax }{figure.caption.26}{}}
