\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Example observation record sent to the CU model at step $N$ of a meeting task. The \textbf  {context} section provides text from prior steps (audio transcriptions and visual narrations persist after images are pruned). The \textbf  {new} section contains the current audio transcription and the post-action screenshot (image). In this case, no keyframes were captured (the slide did not change), so only the screenshot is included as an image. The task instruction is appended at the end.\relax }}{5}{figure.caption.4}\protected@file@percent }
\newlabel{fig:obsrecord}{{4}{5}{Example observation record sent to the CU model at step $N$ of a meeting task. The \textbf {context} section provides text from prior steps (audio transcriptions and visual narrations persist after images are pruned). The \textbf {new} section contains the current audio transcription and the post-action screenshot (image). In this case, no keyframes were captured (the slide did not change), so only the screenshot is included as an image. The task instruction is appended at the end.\relax }{figure.caption.4}{}}
