\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {Observation activity per category.} Stacked bars show the percentage of steps where each observation channel fires. The gray ``idle'' portion represents steps where both gates suppress processing---the AOI does nothing beyond sub-millisecond gate checks. Categories naturally cluster: D\nobreakspace  {}(carousel) is highly visual, G/H\nobreakspace  {}(phone/\allowbreak  {}interview) are audio-only, B\nobreakspace  {}(meeting) uses both channels. On average, 57.6\% of steps are idle---confirming the ``scales to zero'' design.\relax }}{14}{figure.caption.14}\protected@file@percent }
\newlabel{fig:obsactivity}{{8}{14}{\textbf {Observation activity per category.} Stacked bars show the percentage of steps where each observation channel fires. The gray ``idle'' portion represents steps where both gates suppress processing---the AOI does nothing beyond sub-millisecond gate checks. Categories naturally cluster: D~(carousel) is highly visual, G/H~(phone/\allowbreak {}interview) are audio-only, B~(meeting) uses both channels. On average, 57.6\% of steps are idle---confirming the ``scales to zero'' design.\relax }{figure.caption.14}{}}
