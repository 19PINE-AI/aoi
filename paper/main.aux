\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Per-step observation statistics for Claude Sonnet\nobreakspace  {}4.6 + AOI full, broken down by task category. \%\,KF = percentage of steps where at least one keyframe was captured. KF/Step = average keyframes per step. \%\,Audio = percentage of steps with audio transcription. Audio-heavy categories (A, B, G, H) show 27--74\% audio activation. Visually dynamic categories (D, J) average 0.55--1.38 keyframes per step. Static categories (G, H) produce zero keyframes---the pixel and CLIP gates correctly suppress extraction when only audio changes.\relax }}{13}{table.caption.13}\protected@file@percent }
\newlabel{tab:perstep}{{6}{13}{Per-step observation statistics for Claude Sonnet~4.6 + AOI full, broken down by task category. \%\,KF = percentage of steps where at least one keyframe was captured. KF/Step = average keyframes per step. \%\,Audio = percentage of steps with audio transcription. Audio-heavy categories (A, B, G, H) show 27--74\% audio activation. Visually dynamic categories (D, J) average 0.55--1.38 keyframes per step. Static categories (G, H) produce zero keyframes---the pixel and CLIP gates correctly suppress extraction when only audio changes.\relax }{table.caption.13}{}}
