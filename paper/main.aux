\newlabel{sec:perstep}{{7.3}{20}{Per-Step Observation Statistics}{subsection.7.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {14}{\ignorespaces Per-step observation statistics for \textbf  {Claude Sonnet\nobreakspace  {}4.6 + AOI\nobreakspace  {}full}, broken down by task category. \%\,KF = percentage of steps where at least one keyframe was captured. KF/Step = average keyframes per step. \%\,Audio = percentage of steps with audio transcription. Audio-heavy categories (A, B, G, H) show 26--74\% audio activation. Visually dynamic categories (D, J) average 0.55--1.38 keyframes per step. Audio-only categories (G, H) produce zero keyframes---the pixel and CLIP gates correctly suppress extraction when only audio changes.\relax }}{21}{table.caption.21}\protected@file@percent }
\newlabel{tab:perstep}{{14}{21}{Per-step observation statistics for \textbf {Claude Sonnet~4.6 + AOI~full}, broken down by task category. \%\,KF = percentage of steps where at least one keyframe was captured. KF/Step = average keyframes per step. \%\,Audio = percentage of steps with audio transcription. Audio-heavy categories (A, B, G, H) show 26--74\% audio activation. Visually dynamic categories (D, J) average 0.55--1.38 keyframes per step. Audio-only categories (G, H) produce zero keyframes---the pixel and CLIP gates correctly suppress extraction when only audio changes.\relax }{table.caption.21}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.4}Efficiency}{21}{subsection.7.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {15}{\ignorespaces Efficiency and cost across observation configurations on the 100-task benchmark for the five models with full instrumented runs. Grok-4 is excluded because its $\sim $80--180\,s/call latency floor distorts the cost/latency picture (Section\nobreakspace  {}\ref  {sec:grok}). Avg Steps = mean steps per task (lower is better). Obs Overhead = total observation processing time per task, including screenshot capture (${\sim }2$\,s/step) plus CLIP encoding, keyframe selection, and audio processing for AOI configurations. Tokens are accounted as input\nobreakspace  {}+\nobreakspace  {}output per task; per-step prompt tokens are taken from each provider's reported usage when available, with a fallback estimate of $\lceil \textit  {chars}/4\rceil $ for text and $\lceil w h / (14^2)\rceil $ for each image at vendor patch size 14 ($1024{\times }768$ image $\to $ ${\sim }4{,}000$ tokens, consistent with vendor docs); see \texttt  {experiments/compute\_tokens.py}. \$\nobreakspace  {}/\nobreakspace  {}100 tasks computed at May 2026 list prices: Claude\nobreakspace  {}Sonnet\nobreakspace  {}4.6 \$3/Mtok in, \$15/Mtok out; GPT-5.4 \$5/\$15; Gemini\nobreakspace  {}2.5\nobreakspace  {}Flash \$0.30/\$2.50; EvoCUA-32B and Fara-7B run locally. Despite per-step observation overhead, the AOI reduces \emph  {cost} by 15--50\% across the three cloud models (50\% on Claude, 15\% on GPT-5.4, 50\% on Gemini\nobreakspace  {}2.5\nobreakspace  {}Flash) because the step count drops more than the per-step input grows.\relax }}{22}{table.caption.23}\protected@file@percent }
\newlabel{tab:efficiency}{{15}{22}{Efficiency and cost across observation configurations on the 100-task benchmark for the five models with full instrumented runs. Grok-4 is excluded because its $\sim $80--180\,s/call latency floor distorts the cost/latency picture (Section~\ref {sec:grok}). Avg Steps = mean steps per task (lower is better). Obs Overhead = total observation processing time per task, including screenshot capture (${\sim }2$\,s/step) plus CLIP encoding, keyframe selection, and audio processing for AOI configurations. Tokens are accounted as input~+~output per task; per-step prompt tokens are taken from each provider's reported usage when available, with a fallback estimate of $\lceil \textit {chars}/4\rceil $ for text and $\lceil w h / (14^2)\rceil $ for each image at vendor patch size 14 ($1024{\times }768$ image $\to $ ${\sim }4{,}000$ tokens, consistent with vendor docs); see \texttt {experiments/compute\_tokens.py}. \$~/~100 tasks computed at May 2026 list prices: Claude~Sonnet~4.6 \$3/Mtok in, \$15/Mtok out; GPT-5.4 \$5/\$15; Gemini~2.5~Flash \$0.30/\$2.50; EvoCUA-32B and Fara-7B run locally. Despite per-step observation overhead, the AOI reduces \emph {cost} by 15--50\% across the three cloud models (50\% on Claude, 15\% on GPT-5.4, 50\% on Gemini~2.5~Flash) because the step count drops more than the per-step input grows.\relax }{table.caption.23}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.5}Static-Task Verification (Static-50)}{22}{subsection.7.5}\protected@file@percent }
\newlabel{sec:static}{{7.5}{22}{Static-Task Verification (Static-50)}{subsection.7.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {16}{\ignorespaces Static-50 verification: Claude Sonnet\nobreakspace  {}4.6 on 50 pure-HTML tasks (no dynamic content). The AOI's pixel gate suppresses keyframe extraction (total keyframes = 0) and the volume gate suppresses audio processing (audio segments = 0): the perception pipeline runs but never produces an observation, validating the gates' suppression behaviour. The AOI's success rate is comparable to Standard, confirming no degradation on static work.\relax }}{23}{table.caption.24}\protected@file@percent }
\newlabel{tab:static}{{16}{23}{Static-50 verification: Claude Sonnet~4.6 on 50 pure-HTML tasks (no dynamic content). The AOI's pixel gate suppresses keyframe extraction (total keyframes = 0) and the volume gate suppresses audio processing (audio segments = 0): the perception pipeline runs but never produces an observation, validating the gates' suppression behaviour. The AOI's success rate is comparable to Standard, confirming no degradation on static work.\relax }{table.caption.24}{}}
\@writefile{lot}{\contentsline {table}{\numberline {17}{\ignorespaces Decomposing the AOI gain into prompt-format vs.\ perception on DynaCU-Bench (100 tasks). \textbf  {Standard} is a raw screenshot. \textbf  {standard\_structured} adds the AOI's structured observation-record prompt format (DOM element list, prior-step text trajectory) but no keyframes and no audio. \textbf  {AOI\nobreakspace  {}full} is the full perception layer. $\Delta _\text  {prompt}$ isolates the prompt-format effect; $\Delta _\text  {percept}$ isolates the keyframe + audio + narration contribution. All numbers are paired McNemar mid-$p$ vs.\ Standard. All five models in this table are evaluated directly; the two open-source rows are included after patching the vLLM platform detection to bypass the broken NVML library (see Section\nobreakspace  {}\ref  {sec:limitations}). Gemini\nobreakspace  {}3\nobreakspace  {}Flash is reported separately in Table\nobreakspace  {}\ref  {tab:gemini3_decomp}.\relax }}{23}{table.caption.25}\protected@file@percent }
\newlabel{tab:structured}{{17}{23}{Decomposing the AOI gain into prompt-format vs.\ perception on DynaCU-Bench (100 tasks). \textbf {Standard} is a raw screenshot. \textbf {standard\_structured} adds the AOI's structured observation-record prompt format (DOM element list, prior-step text trajectory) but no keyframes and no audio. \textbf {AOI~full} is the full perception layer. $\Delta _\text {prompt}$ isolates the prompt-format effect; $\Delta _\text {percept}$ isolates the keyframe + audio + narration contribution. All numbers are paired McNemar mid-$p$ vs.\ Standard. All five models in this table are evaluated directly; the two open-source rows are included after patching the vLLM platform detection to bypass the broken NVML library (see Section~\ref {sec:limitations}). Gemini~3~Flash is reported separately in Table~\ref {tab:gemini3_decomp}.\relax }{table.caption.25}{}}
