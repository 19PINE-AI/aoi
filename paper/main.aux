\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Efficiency statistics across observation configurations. Avg Steps = mean steps per task (lower is better---fewer steps means faster task completion). Obs Overhead = total observation processing time per task, including screenshot capture (${\sim }2$\,s/step baseline for both standard and AOI) plus CLIP encoding, keyframe selection, and audio processing for AOI configurations.\relax }}{15}{table.caption.15}\protected@file@percent }
\newlabel{tab:efficiency}{{7}{15}{Efficiency statistics across observation configurations. Avg Steps = mean steps per task (lower is better---fewer steps means faster task completion). Obs Overhead = total observation processing time per task, including screenshot capture (${\sim }2$\,s/step baseline for both standard and AOI) plus CLIP encoding, keyframe selection, and audio processing for AOI configurations.\relax }{table.caption.15}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Static task verification. On 10 purely static tasks, the AOI extracts zero keyframes and zero audio segments, confirming that the pixel gate and volume gate correctly suppress observation when no dynamic content is present. The AOI does not degrade performance on static work.\relax }}{15}{table.caption.16}\protected@file@percent }
\newlabel{tab:static}{{8}{15}{Static task verification. On 10 purely static tasks, the AOI extracts zero keyframes and zero audio segments, confirming that the pixel gate and volume gate correctly suppress observation when no dynamic content is present. The AOI does not degrade performance on static work.\relax }{table.caption.16}{}}
