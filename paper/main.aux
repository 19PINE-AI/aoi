\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces \textbf  {The AOI's small $+9$\,pp net on Gemini\nobreakspace  {}3\nobreakspace  {}Flash is a three-way cancellation, not saturation.} Audio ($+12$) and the structured scaffold ($+9$) help as on every other model, but the keyframe-image stream \emph  {regresses} $-12$\,pp---so the default bundle nets only $36\to 45$. Dropping just the keyframes recovers $57/100$ ($+21$\,pp over Standard), showing the slack is real and the bundle merely mis-tuned. Underlying per-mode and per-family tables are in Appendix\nobreakspace  {}\ref  {app:gemini3}.\relax }}{16}{figure.caption.12}\protected@file@percent }
\newlabel{fig:gemini3}{{10}{16}{\textbf {The AOI's small $+9$\,pp net on Gemini~3~Flash is a three-way cancellation, not saturation.} Audio ($+12$) and the structured scaffold ($+9$) help as on every other model, but the keyframe-image stream \emph {regresses} $-12$\,pp---so the default bundle nets only $36\to 45$. Dropping just the keyframes recovers $57/100$ ($+21$\,pp over Standard), showing the slack is real and the bundle merely mis-tuned. Underlying per-mode and per-family tables are in Appendix~\ref {app:gemini3}.\relax }{figure.caption.12}{}}
