\citation{qwen3vl}
\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces Selection-method ablation on an open-source vision model (Qwen3-VL-32B-Instruct via OpenRouter), 50 visual-temporal tasks (categories C, D, E, F, J). The three selection methods cluster within a narrow band, mirroring the Claude Sonnet\nobreakspace  {}4.6 pattern. Pairwise McNemar tests find no significant differences ($p>0.4$ for every pair), confirming that the convergence finding is not Claude-specific.\relax }}{18}{table.caption.17}\protected@file@percent }
\newlabel{tab:oss_selection}{{11}{18}{Selection-method ablation on an open-source vision model (Qwen3-VL-32B-Instruct via OpenRouter), 50 visual-temporal tasks (categories C, D, E, F, J). The three selection methods cluster within a narrow band, mirroring the Claude Sonnet~4.6 pattern. Pairwise McNemar tests find no significant differences ($p>0.4$ for every pair), confirming that the convergence finding is not Claude-specific.\relax }{table.caption.17}{}}
\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces Pairwise McNemar's exact mid-$p$ tests between successive ablation tiers on the same 100 tasks (Claude Sonnet\nobreakspace  {}4.6). Each row tests whether the labelled configuration differs significantly from the previous one. ``$b$'' / ``$c$'' are the discordant counts (success in only the previous / only the current configuration). The selection-method group is statistically indistinguishable; the between-tier transitions are highly significant.\relax }}{18}{table.caption.18}\protected@file@percent }
\newlabel{tab:ablation_stats}{{12}{18}{Pairwise McNemar's exact mid-$p$ tests between successive ablation tiers on the same 100 tasks (Claude Sonnet~4.6). Each row tests whether the labelled configuration differs significantly from the previous one. ``$b$'' / ``$c$'' are the discordant counts (success in only the previous / only the current configuration). The selection-method group is statistically indistinguishable; the between-tier transitions are highly significant.\relax }{table.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {CLIP threshold ($\theta $) sensitivity} on 40 visual tasks (categories C--F) with Claude Sonnet\nobreakspace  {}4.6. Error bars are 95\% Wilson confidence intervals at $N{=}40$ ($\pm $9.5--12.1\,pp). Point estimates remain within an 80--90\% band (shaded) across a $15\times $ range of $\theta $, but the CIs overlap heavily, so we cannot distinguish individual thresholds at this sample size. The bimodal distribution of CLIP distances---near-zero for unchanged content, large for meaningful changes---makes the method naturally insensitive to $\theta $.\relax }}{19}{figure.caption.19}\protected@file@percent }
\newlabel{fig:theta}{{7}{19}{\textbf {CLIP threshold ($\theta $) sensitivity} on 40 visual tasks (categories C--F) with Claude Sonnet~4.6. Error bars are 95\% Wilson confidence intervals at $N{=}40$ ($\pm $9.5--12.1\,pp). Point estimates remain within an 80--90\% band (shaded) across a $15\times $ range of $\theta $, but the CIs overlap heavily, so we cannot distinguish individual thresholds at this sample size. The bimodal distribution of CLIP distances---near-zero for unchanged content, large for meaningful changes---makes the method naturally insensitive to $\theta $.\relax }{figure.caption.19}{}}
