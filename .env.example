# DynaCU-Bench / AOI — API keys and runtime configuration.
# Copy to `.env` and fill in the keys for the models you intend to evaluate.
# (`.env` is gitignored.) Only the keys for the models you run are required.

# ── Closed-source CU models ───────────────────────────────────────────────
ANTHROPIC_API_KEY=        # Claude (claude-sonnet-4-6, claude-opus-4-6)
OPENAI_API_KEY=           # GPT-5.4 / GPT-4o / OpenAI Realtime
GEMINI_API_KEY=           # Gemini 2.5 / 3 Flash, Gemini Live, LLM judge
XAI_API_KEY=              # Grok-4 / 4.3 / 4-fast / Grok Voice

# ── Open-source models via OpenRouter (Qwen3-VL, GPT-5.4-or, etc.) ─────────
# Routed through the OpenAI-compatible client; set both:
OPENROUTER_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1   # uncomment to route OpenAI client via OpenRouter

# ── Locally served models (vLLM) ──────────────────────────────────────────
# Fara-7B, EvoCUA-32B, UI-TARS, etc. are served with vLLM on localhost.
VLLM_API_KEY=EMPTY        # any non-empty token vLLM accepts

# ── Whisper ASR microservice ──────────────────────────────────────────────
# Started separately (python -m aoi.whisper_service). Override host/port if needed:
# WHISPER_URL=http://localhost:8786

# ── Optional: override the Python interpreter used by shell launch scripts ─
# PYTHON=python
# VENV=$HOME/aoi-env
